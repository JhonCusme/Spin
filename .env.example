# ═══════════════════════════════════════════════
#  SpinDraw — Variables de Entorno
#  Copia este archivo como .env y llena los valores
# ═══════════════════════════════════════════════

# ── SERVIDOR ──────────────────────────────────
PORT=3000
FRONTEND_URL=https://tu-dominio.com

# ── MONGODB ATLAS ─────────────────────────────
# Crea cuenta gratis en https://mongodb.com/atlas
# Crea un cluster gratis (M0) y copia el connection string
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/spindraw

# ── JWT ───────────────────────────────────────
# Pon cualquier string largo y aleatorio aquí
JWT_SECRET=cambia_esto_por_algo_muy_secreto_2024

# ── PAYPAL ────────────────────────────────────
# Crea app en https://developer.paypal.com
# Para pruebas usa: sandbox
# Para producción cambia a: live
PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=tu_paypal_client_id
PAYPAL_CLIENT_SECRET=tu_paypal_client_secret

# ── EMAIL (Gmail) ─────────────────────────────
# Usa una cuenta Gmail con "contraseña de aplicación"
# Ve a: Google Account > Seguridad > Verificación en 2 pasos > Contraseñas de aplicación
EMAIL_USER=tu_email@gmail.com
EMAIL_PASS=contraseña_de_aplicacion_16_chars

# ── ADMIN ─────────────────────────────────────
# El username que tendrá acceso al panel admin
ADMIN_USERNAME=admin
ADMIN_EMAIL=tu_email_admin@gmail.com
