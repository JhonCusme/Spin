# .htaccess - Configuración de servidor Apache (OPCIONAL)
# 
# NOTA: Este archivo solo se aplica si usas Apache como servidor web
# Si usas Node.js (como en Render), puedes ignorar este archivo
#
# Para usarlo:
# 1. Asegúrate de que mod_rewrite está habilitado en Apache
# 2. Copia este archivo a la raíz de tu sitio web
# 3. Ajusta las rutas según sea necesario

# Habilitar reescritura de URLs
<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # Forzar HTTPS (importante para AdSense)
  RewriteCond %{HTTPS} off
  RewriteRule ^(.*)$ https://%{HTTP_HOST}%{REQUEST_URI} [L,R=301]
  
  # Forzar www o sin www (elige uno)
  # Opción 1: Forzar www
  # RewriteCond %{HTTP_HOST} !^www\. [NC]
  # RewriteRule ^(.*)$ https://www.%{HTTP_HOST}/$1 [L,R=301]
  
  # Opción 2: Forzar sin www
  RewriteCond %{HTTP_HOST} ^www\.(.*)$ [NC]
  RewriteRule ^(.*)$ https://%1/$1 [L,R=301]
</IfModule>

# Comprimir contenido (mejor performance)
<IfModule mod_deflate.c>
  AddOutputFilterByType DEFLATE text/plain
  AddOutputFilterByType DEFLATE text/html
  AddOutputFilterByType DEFLATE text/xml
  AddOutputFilterByType DEFLATE text/css
  AddOutputFilterByType DEFLATE text/javascript
  AddOutputFilterByType DEFLATE application/xml
  AddOutputFilterByType DEFLATE application/xhtml+xml
  AddOutputFilterByType DEFLATE application/rss+xml
  AddOutputFilterByType DEFLATE application/javascript
  AddOutputFilterByType DEFLATE application/x-javascript
  AddOutputFilterByType DEFLATE application/json
</IfModule>

# Caché del navegador (mejor performance)
<IfModule mod_expires.c>
  ExpiresActive On
  
  # Imágenes
  ExpiresByType image/jpeg "access plus 1 year"
  ExpiresByType image/gif "access plus 1 year"
  ExpiresByType image/png "access plus 1 year"
  ExpiresByType image/webp "access plus 1 year"
  ExpiresByType image/svg+xml "access plus 1 year"
  
  # CSS y JavaScript
  ExpiresByType text/css "access plus 1 month"
  ExpiresByType application/javascript "access plus 1 month"
  ExpiresByType text/javascript "access plus 1 month"
  
  # Fuentes
  ExpiresByType font/ttf "access plus 1 year"
  ExpiresByType font/otf "access plus 1 year"
  ExpiresByType font/woff "access plus 1 year"
  ExpiresByType font/woff2 "access plus 1 year"
  ExpiresByType application/font-woff "access plus 1 year"
  
  # HTML (menos caché)
  ExpiresByType text/html "access plus 1 week"
  
  # JSON
  ExpiresByType application/json "access plus 1 day"
  
  # XML
  ExpiresByType application/xml "access plus 1 day"
  ExpiresByType text/xml "access plus 1 day"
</IfModule>

# Headers de seguridad
<IfModule mod_headers.c>
  # Prevenir clickjacking
  Header always set X-Frame-Options "DENY"
  
  # Prevenir MIME type sniffing
  Header always set X-Content-Type-Options "nosniff"
  
  # XSS Protection
  Header always set X-XSS-Protection "1; mode=block"
  
  # Referrer Policy
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
  
  # HSTS (Strict Transport Security)
  Header always set Strict-Transport-Security "max-age=31536000; includeSubDomains"
  
  # Permitir Google Analytics y AdSense
  Header set Access-Control-Allow-Origin "https://pagead2.googlesyndication.com"
</IfModule>

# Bloquear acceso a archivos sensibles
<FilesMatch "(?i)(\.env|\.git|\.gitignore|firebase-key\.json|package\.json|README|composer\.json)">
  Deny from all
</FilesMatch>

# Bloquear acceso a directorios
<DirectoryMatch "(?i)(node_modules|\.git|admin/secrets)">
  Deny from all
</DirectoryMatch>

# Permitir acceso a archivos públicos
<IfModule mod_rewrite.c>
  RewriteEngine On
  
  # Permitir acceso a robots.txt y sitemap.xml
  RewriteRule ^(robots\.txt|sitemap\.xml|favicon\.svg|manifest\.json)$ - [L]
  
  # Permitir archivos estáticos
  RewriteCond %{REQUEST_FILENAME} -f
  RewriteCond %{REQUEST_FILENAME} -d
  RewriteRule ^ - [L]
</IfModule>

# Configuración de tipos MIME
<IfModule mod_mime.c>
  AddType application/manifest+json .webmanifest
  AddType application/json .json
  AddEncoding gzip .gz
</IfModule>

# Desabilitar directorios indexables
Options -Indexes
